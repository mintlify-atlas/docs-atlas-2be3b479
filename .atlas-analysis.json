  "publicApiSurface": [
    "QueryEngine.submitMessage(prompt) → AsyncGenerator<SDKMessage>",
    "buildTool(definition) → Tool<Input, Output, Progress>",
    "tool.call() — execute tool and return result",
    "tool.checkPermissions() — tool-specific authorization",
    "tool.validateInput() — reject invalid args early",
    "tool.isEnabled() — feature gate check",
    "tool.isConcurrencySafe() — parallel execution eligibility",
    "StreamingToolExecutor — parallel tool runner",
    "AppStateStore — global application state",
    "useAppState(selector) — React selector-based subscription",
    "AgentTool — sub-agent spawning",
    "MCPTool — MCP protocol wrapper",
    "BashTool — shell command execution",
    "FileReadTool / FileEditTool / FileWriteTool — file operations",
    "TaskCreate/Update/Get/List — persistent task management"
  ]
